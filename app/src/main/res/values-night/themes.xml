<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark variant of the demo app theme. Uses the SDK's frame_* tokens for the
         status bar so the demo blends with onboarding/checkout's dark surface
         instead of clashing with a hardcoded purple. Primary/secondary still use
         Material 2 purples for the demo's own toolbar/buttons. -->
    <style name="Theme.Frame" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/frame_onboarding_header_background</item>
    </style>
</resources>